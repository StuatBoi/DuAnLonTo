<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!-- Import thêm Region -->

<StackPane styleClass="auth-root" stylesheets="@styles1.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.net.demo.RegisterController">

    <VBox alignment="CENTER" styleClass="auth-overlay">

        <VBox alignment="TOP_CENTER" maxWidth="440" spacing="22" styleClass="auth-container">
            <padding>
                <Insets bottom="35" left="45" right="45" top="35" />
            </padding>

            <!-- Logo Brand -->
            <Label style="-fx-font-size: 32px;" styleClass="logo" text="CINEVERSE" />

            <!-- Tiêu đề biểu mẫu -->
            <VBox alignment="CENTER" spacing="6">
                <Label styleClass="auth-title" text="Tạo Tài Khoản" />
                <Label styleClass="auth-subtitle" text="Đăng ký để trải nghiệm xem phim không giới hạn" />
            </VBox>

            <!-- Các trường nhập liệu -->
            <VBox fillWidth="true" spacing="14">
                <!-- Họ và tên -->
                <VBox spacing="5">
                    <Label styleClass="movie-meta" text="Họ và tên" />
                    <HBox alignment="CENTER_LEFT" style="-fx-background-radius: 6px; -fx-border-radius: 6px; -fx-padding: 10px 14px;" styleClass="search-bar">
                        <Label style="-fx-font-size: 14px;" styleClass="search-icon" text="👤 " />
                        <TextField fx:id="fullNameField" promptText="Nguyễn Văn A" style="-fx-font-size: 14px;" styleClass="search-field" HBox.hgrow="ALWAYS" />
                    </HBox>
                </VBox>

                <!-- Email -->
                <VBox spacing="5">
                    <Label styleClass="movie-meta" text="Địa chỉ Email" />
                    <HBox alignment="CENTER_LEFT" style="-fx-background-radius: 6px; -fx-border-radius: 6px; -fx-padding: 10px 14px;" styleClass="search-bar">
                        <Label style="-fx-font-size: 14px;" styleClass="search-icon" text="✉ " />
                        <TextField fx:id="emailField" promptText="name@example.com" style="-fx-font-size: 14px;" styleClass="search-field" HBox.hgrow="ALWAYS" />
                    </HBox>
                </VBox>

                <!-- Mật khẩu -->
                <VBox spacing="5">
                    <Label styleClass="movie-meta" text="Mật khẩu" />
                    <HBox alignment="CENTER_LEFT" style="-fx-background-radius: 6px; -fx-border-radius: 6px; -fx-padding: 10px 14px;" styleClass="search-bar">
                        <Label style="-fx-font-size: 14px;" styleClass="search-icon" text="🔒 " />
                        <PasswordField fx:id="passwordField" promptText="Tối thiểu 6 ký tự" style="-fx-font-size: 14px;" styleClass="search-field" HBox.hgrow="ALWAYS" />
                    </HBox>
                </VBox>
            </VBox>

            <!-- Điều khoản dịch vụ -->
            <HBox alignment="TOP_LEFT" fillHeight="false" spacing="8">
                <CheckBox fx:id="acceptTermsCheckbox" styleClass="auth-checkbox" />
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <Label style="-fx-text-fill: #e2e2e8; -fx-font-size: 12px;" styleClass="movie-meta" text="Tôi đồng ý với Điều khoản dịch vụ" />
                    <Label style="-fx-text-fill: #e2e2e8; -fx-font-size: 12px;" styleClass="movie-meta" text="và Chính sách bảo mật của Cineverse." />
                </VBox>
            </HBox>

            <Label fx:id="errorLabel" style="-fx-text-fill: #ff4d4f; -fx-font-size: 12px;" text="" />

            <!-- Nút hành động -->
            <VBox alignment="CENTER" fillWidth="true" spacing="16">
                <Button fx:id="btnSubmitRegister" maxWidth="1.7976931348623157E308" style="-fx-padding: 12px 24px; -fx-font-size: 14px;" styleClass="btn-primary" text="ĐĂNG KÝ NGAY" />

                <HBox alignment="CENTER" spacing="6">
                    <Label style="-fx-font-size: 13px;" styleClass="movie-meta" text="Đã có tài khoản?" />
                    <Hyperlink fx:id="linkLogin" onAction="#onGoToLogin" style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-padding: 0;" styleClass="see-all" />
                    <Hyperlink fx:id="linkGoToLogin" onAction="#onGoToLogin" prefHeight="23.0" prefWidth="96.0" styleClass="link-red" text="Đăng nhập ngay" />
                </HBox>
            </VBox>

        </VBox>
    </VBox>
</StackPane>
