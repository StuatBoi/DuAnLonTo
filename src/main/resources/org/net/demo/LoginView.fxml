<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane id="page" styleClass="auth-root" stylesheets="@styles1.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.net.demo.LoginController">
    
    <!-- Lớp phủ mờ nền (Overlay) để tạo chiều sâu giống như các trang xem phim hiện đại -->
    <VBox alignment="CENTER" styleClass="auth-overlay">
        
        <VBox alignment="TOP_CENTER" maxWidth="400" spacing="25" styleClass="auth-container">
            <padding>
                <Insets bottom="40" left="45" right="45" top="40" />
            </padding>
            
            <!-- Logo Brand -->
            <Label style="-fx-font-size: 32px;" styleClass="logo" text="CINEVERSE" />
            
            <!-- Tiêu đề biểu mẫu -->
            <VBox alignment="CENTER" spacing="6">
                <Label styleClass="auth-title" text="Đăng Nhập" />
                <Label styleClass="auth-subtitle" text="Chào mừng bạn trở lại với không gian điện ảnh" />
            </VBox>
            
            <!-- Các trường nhập liệu -->
            <VBox fillWidth="true" spacing="16">
                <VBox spacing="6">
                    <Label styleClass="movie-meta" text="Địa chỉ Email" />
                    <HBox alignment="CENTER_LEFT" style="-fx-background-radius: 6px; -fx-border-radius: 6px; -fx-padding: 10px 14px;" styleClass="search-bar">
                        <Label style="-fx-font-size: 14px;" styleClass="search-icon" text="✉ " />
                        <TextField fx:id="emailField" promptText="name@example.com" style="-fx-font-size: 14px;" styleClass="search-field" HBox.hgrow="ALWAYS" />
                    </HBox>
                </VBox>
                
                <VBox spacing="6">
                    <HBox alignment="CENTER_LEFT">
                        <Label styleClass="movie-meta" text="Mật khẩu" />
                        <Region>
                            <HBox.hgrow>
                                <Priority fx:constant="ALWAYS" />
                            </HBox.hgrow>
                        </Region>
                        <Hyperlink style="-fx-font-size: 11px; -fx-padding: 0;" styleClass="auth-link" text="Quên mật khẩu?" />
                    </HBox>
                    <HBox alignment="CENTER_LEFT" style="-fx-background-radius: 6px; -fx-border-radius: 6px; -fx-padding: 10px 14px;" styleClass="search-bar">
                        <Label style="-fx-font-size: 14px;" styleClass="search-icon" text="* " />
                        <PasswordField fx:id="passwordField" promptText="••••••••" style="-fx-font-size: 14px;" styleClass="search-field" HBox.hgrow="ALWAYS" />
                    </HBox>
                </VBox>
            </VBox>
            
            <!-- Nút hành động -->
            <VBox alignment="CENTER" fillWidth="true" spacing="16">
                <Button fx:id="btnSubmitLogin" maxWidth="1.7976931348623157E308" style="-fx-padding: 12px 24px; -fx-font-size: 14px;" styleClass="btn-primary" text="ĐẮNG NHẬP" />
                
                <HBox alignment="CENTER" spacing="6">
                    <Label style="-fx-font-size: 13px;" styleClass="movie-meta" text="Bạn mới biết đến Cineverse?" />
                    <Hyperlink fx:id="linkRegister" onAction="#onGoToRegister" onMouseClicked="#initialize" style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-padding: 0;" styleClass="see-all" text="Đăng ký ngay" />
                </HBox>
            </VBox>
            
        </VBox>
    </VBox>
</StackPane>
