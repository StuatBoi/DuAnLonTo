<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="movieCard" styleClass="movie-card" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1">
    <StackPane styleClass="movie-thumb" VBox.vgrow="ALWAYS">
        <ImageView fx:id="movieThumb" fitHeight="240" fitWidth="175" preserveRatio="true" styleClass="thumb-img" />
        <Label fx:id="qualityBadge" styleClass="quality-badge" text="HD" />
        <Label fx:id="starBadge" styleClass="star-badge" text="★ 0.0" />
    </StackPane>
    <VBox spacing="3" styleClass="movie-info">
        <Label fx:id="movieTitle" styleClass="movie-title" text="Tên phim" wrapText="true" />
        <Label fx:id="movieMeta" styleClass="movie-meta" text="Thể loại • Năm" />
    </VBox>
</VBox>